<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Alerte Casino Défilante</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@900&display=swap');

        body {
            margin: 0;
            padding: 0;
            background: transparent;
            display: flex;
            align-items: flex-end; /* Calé en bas par défaut, mais tu peux le mettre où tu veux */
            width: 100vw;
            height: 100vh;
            overflow: hidden;
        }

        /* 🚨 LE BANDEAU DÉFILANT */
        .ticker-wrap {
            width: 100%;
            background: rgba(10, 10, 10, 0.95);
            border-top: 4px solid #53fc18;
            border-bottom: 4px solid #53fc18;
            box-shadow: 0 0 30px rgba(83, 252, 24, 0.4);
            padding: 12px 0;
            overflow: hidden;
            white-space: nowrap;
        }

        /* 🏃 LE CONTENEUR EN MOUVEMENT */
        .ticker {
            display: inline-block;
            padding-left: 100%;
            animation: marquee 20s linear infinite; /* Vitesse du défilement */
        }

        /* ✍️ LE TEXTE STYLE CASINO FLASH */
        .ticker-item {
            display: inline-block;
            padding: 0 3rem;
            font-family: 'Montserrat', sans-serif;
            font-size: 28px;
            font-weight: 900;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(83, 252, 24, 0.6);
        }

        /* Accentuation flash sur certains mots clés */
        .highlight {
            color: #53fc18;
            text-shadow: 0 0 15px #53fc18;
        }

        /* L'ANIMATION DU DÉFILEMENT DE DROITE À GAUCHE */
        @keyframes marquee {
            0% { transform: translate3d(0, 0, 0); }
            100% { transform: translate3d(-100%, 0, 0); }
        }
    </style>
</head>
<body>

    <div class="ticker-wrap">
        <div class="ticker">
            <div class="ticker-item">⚠️ <span class="highlight">MOMENT SPÉCIAL</span> EN COURS 🎰</div>
            <div class="ticker-item">🥜 SÉCURISEZ VOS <span class="highlight">CACAHUÈTES</span>, LE SCAM COMMENCE... 💸</div>
            <div class="ticker-item">🔥 BIENVENUE DANS LA <span class="highlight">SALLE INTERDITE</span> 💀</div>
            <div class="ticker-item">🎰 LES JEUX SONT FAITS, RIEN NE VA PLUS ! 🔄</div>
        </div>
    </div>

</body>
</html>
